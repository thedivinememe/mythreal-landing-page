# Copy this file to `.env` and fill in values for local Netlify Dev runs.
# In production, set the same vars under Netlify > Site settings > Environment variables.
# Never commit `.env` — it is gitignored.

# Required: Anthropic API key for character text synthesis.
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required: OpenAI API key for portrait generation.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional overrides.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_IMAGE_MODEL=gpt-image-1
# FORGE_RATE_LIMIT=20
